# Required: create a Feishu/Lark custom app with bot capability first.
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=your_app_secret

# Optional runtime settings.
# FEISHU_CLAUDE_CODE_WORKDIR defaults to your home directory.
FEISHU_CLAUDE_CODE_WORKDIR=

# Optional: installer tries to auto-detect these.
PYTHON_BIN=
NODE_BIN=
CLAUDE_BIN=

# Optional Claude Code behavior.
# Use "auto" for Feishu-driven unattended runs. Safer alternatives include
# "acceptEdits", "dontAsk", "plan", or "default" depending on your workflow.
CLAUDE_PERMISSION_MODE=auto
CLAUDE_MODEL=
CLAUDE_EFFORT=
CLAUDE_MAX_BUDGET_USD=
CLAUDE_ALLOWED_TOOLS=
CLAUDE_DISALLOWED_TOOLS=
CLAUDE_EXTRA_ARGS=

# Optional context/topic settings.
FEISHU_TOPIC_IDLE_SECONDS=7200
FEISHU_TOPIC_NOTICE_ENABLED=1
FEISHU_TASK_PROGRESS_SECONDS=7200
FEISHU_ACK_TEXT=收到，我要开始干活了，稍等我
